# Адреса серверов
BACKEND_IP=your-backend-ip
YANDEX_IP=your-yandex-relay-ip
# Секрет прокси (полный, с префиксом ee) — получить через: curl http://localhost:9091/v1/users на proxy-backend
PROXY_SECRET=ee<32_hex_chars><domain_hex>

# Optional residential HTTP CONNECT proxy for sing-box egress bridge.
SING_BOX_HTTP_PROXY_HOST=example.proxy.local
SING_BOX_HTTP_PROXY_PORT=3128
SING_BOX_HTTP_PROXY_USER=change-me
SING_BOX_HTTP_PROXY_PASS=change-me
